{
	"biz_id": "saddlewest",
	"check_in": true,
	"auth_required": true,
	"error_auth": {
		"title": "Woops!",
		"content": "Can't play if you ain't authenticated!"
	},
	"styling": {
		"fonts": {
			"headers": {
				"family": "Montserrat",
				"weight": 700,
				"style": "italic"
			},
			"body": {
				"family": "Montserrat",
				"weight": "normal"
			},
			"formlabels": {
				"family": "Montserrat",
				"weight": "bold"
			}
		}
	},
	"FORM": {
		"fields": [
			{
				"type": "info",
				"justify": "center",
				"markdown": "# Your Voice Matters"
			},
			{
				"type": "info",
				"justify": "center",
				"markdown": "## Thanks for spending time with us! We'd love to hear about your visit."
			},
			{
				"type": "info",
				"markdown": "---"
			},
			{
				"id": "rating",
				"label": "How was your visit to Saddle West?",
				"type": "select",
				"range": ["⭑⭑⭑⭑⭑","⭑⭑⭑⭑","⭑⭑⭑","⭑⭑","⭑"],
				"required": false
			},
			{
				"id": "highlight",
				"label": "What made your visit great?",
				"type": "multi-select",
				"range": ["Casino floor experience","Hotel room","RV resort","Food & dining","Staff & service","Overall atmosphere", "Something else"],
				"required": false,
				"conditional": {
					"field": "rating",
					"values": ["⭑⭑⭑⭑⭑","⭑⭑⭑⭑"]
				}
			},		
			{
				"id": "fellshort",
				"label": "What fell short of your expectations?",
				"type": "multi-select",
				"range": ["Casino floor experience","Hotel room","RV resort","Food & dining","Staff & service","Overall atmosphere", "Something else"],
				"required": false,
				"conditional": {
					"field": "rating",
					"values": ["⭑⭑⭑","⭑⭑","⭑"]
				}
			},			
			{
				"id": "positivecomments",
				"label": "Anything you'd like to share about what stood out?",
				"type": "textarea",
				"rows": 2,
				"required": false,
				"conditional": {
					"field": "rating",
					"values": ["⭑⭑⭑⭑⭑","⭑⭑⭑⭑"]
				}
			},		
			{
				"id": "negativecomments",
				"label": "We want to make this right. What can we do better?",
				"type": "textarea",
				"rows": 2,
				"required": false,
				"conditional": {
					"field": "rating",
					"values": ["⭑⭑⭑","⭑⭑","⭑"]
				}
			},						
			{
				"id": "team",
				"label": "Did anyone on our team provide exceptional service?",
				"type": "textarea",
				"rows": 2,
				"required": false
			},
			{
				"id": "recommend",
				"label": "How likely are you to recommend us to friends and family?",
				"type": "select",
				"range": ["definitely will","very likely","maybe","not likely","will not"],
				"required": false
			},
			{
				"type": "info",
				"markdown": "   "
			},
			{
				"type": "fields_group",
				"bgcolor": "#D8B48A",
				"fields": [
					{
						"id": "firstname",
						"label": "First Name:",
						"type": "text",
						"required": false
					},
					{
						"id": "lastname",
						"label": "Last Name:",
						"type": "text",
						"required": false
					},
					{
						"id": "email",
						"label": "Email:",
						"type": "email",
						"required": false
					},
					{
						"id": "address",
						"label": "Address:",
						"type": "textarea",
						"rows": 3,
						"required": false
					}
				]
			},
			{
				"id": "optin",
				"label": "By checking this box, I agree to receive promotional emails from Saddle West, including exclusive offers, promotions, dining specials, and casino event updates. I understand I can unsubscribe at any time.\n\n",
				"type": "checkbox",
				"required": false
			},
			{
				"type": "info",
				"markdown": "   "
			}
		],
		"submit": {
			"label": "Submit Feedback",
			"color": "#20363d"
		},
		"notify": {
			"opt_in": "rating",
			"trigger_values": ["⭑⭑", "⭑"],
			"message": "**Guest Feedback Notification**\nFrom: {firstname} {lastname} - {_mob)\nRating: {rating}\nComments: {negativecomments}",
			"mobiles": [
				"+15039533423",
				"+16462474444"
			]
		}
	},
	"MAIN": {
		"body_md": "# Thank You!\n\nWe appreciate your feedback, and thank you for visiting Saddle West Hotel, Casino & RV Resort."
	}
}
